{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "botAppId": {
      "value": "${BOT_APP_ID}"
    },
    "botAppSecret": {
      "value": "${BOT_APP_SECRET}"
    },
    "botTenantId": {
      "value": "${BOT_TENANT_ID}"
    },
    "easyAuthAppId": {
      "value": "${EASYAUTH_APP_ID}"
    },
    "containerImage": {
      "value": "${SERVICE_OPENCLAW_IMAGE_NAME}"
    },
    "useExpressEnv": {
      "value": "${USE_EXPRESS_ENV=false}"
    },
    "useSandbox": {
      "value": "${USE_SANDBOX=false}"
    },
    "executionMode": {
      "value": "${EXECUTION_MODE=inproc}"
    },
    "workerIdentityClientId": {
      "value": "${WORKER_IDENTITY_CLIENT_ID=}"
    },
    "execAcrImage": {
      "value": "${EXEC_ACR_IMAGE=}"
    },
    "execImageDigest": {
      "value": "${EXEC_IMAGE_DIGEST=}"
    },
    "execDiskId": {
      "value": "${EXEC_DISK_ID=}"
    },
    "execSnapshot": {
      "value": "${EXEC_SNAPSHOT=}"
    },
    "skipStorage": {
      "value": "${SKIP_STORAGE=false}"
    },
    "openaiLocation": {
      "value": "${AZURE_OPENAI_LOCATION=}"
    }
  }
}
