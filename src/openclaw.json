{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": ["*"]
    }
  },
  "agents": {
    "defaults": {
      "model": "openai/gpt-5-mini"
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "baseUrl": "${OPENAI_BASE_URL}",
        "models": [
          {
            "id": "gpt-5-mini",
            "name": "GPT-5 Mini",
            "api": "openai-responses"
          }
        ]
      }
    }
  }
}
