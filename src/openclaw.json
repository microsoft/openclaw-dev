{
  "gateway": {
    "mode": "local",
    "controlUi": {
      "allowedOrigins": ["*"]
    }
  },
  "agents": {
    "defaults": {
      "model": "openai/gpt-5-mini"
    }
  },
  "channels": {
    "msteams": {
      "enabled": true,
      "appId": "${MSTEAMS_APP_ID}",
      "appPassword": "${MSTEAMS_APP_PASSWORD}",
      "tenantId": "${MSTEAMS_TENANT_ID}",
      "webhook": {
        "port": 3978
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openai": {
        "baseUrl": "${OPENAI_BASE_URL}",
        "models": [
          {
            "id": "gpt-5-mini",
            "name": "GPT-5 Mini",
            "api": "openai-responses"
          }
        ]
      }
    }
  }
}
