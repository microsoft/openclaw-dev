{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.23/MicrosoftTeams.schema.json",
  "manifestVersion": "1.23",
  "version": "1.0.0",
  "id": "APP_ID_PLACEHOLDER",
  "name": { "short": "OpenClaw", "full": "OpenClaw AI Assistant" },
  "developer": {
    "name": "Microsoft",
    "websiteUrl": "https://github.com/microsoft/openclaw-dev",
    "privacyUrl": "https://github.com/microsoft/openclaw-dev",
    "termsOfUseUrl": "https://github.com/microsoft/openclaw-dev"
  },
  "description": {
    "short": "AI assistant powered by OpenClaw",
    "full": "Your personal AI assistant running securely in the Microsoft Cloud. Ask questions, draft documents, review code, summarize meetings, and more — all from Teams."
  },
  "icons": { "outline": "outline.png", "color": "color.png" },
  "accentColor": "#E94560",
  "bots": [
    {
      "botId": "APP_ID_PLACEHOLDER",
      "scopes": ["personal"],
      "isNotificationOnly": false,
      "supportsCalling": false,
      "supportsVideo": false,
      "supportsFiles": false
    }
  ]
}
